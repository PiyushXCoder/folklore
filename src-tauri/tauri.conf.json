{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "folklore",
  "version": "0.1.1",
  "identifier": "in.piyush.folklore",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "folklore",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["superlore"],
        "name": "superlore bundle",
        "description": "superlore document bundle",
        "mimeType": "application/x-superlore",
        "role": "Viewer"
      },
      {
        "ext": ["mdx"],
        "name": "MDX document",
        "description": "MDX document",
        "mimeType": "text/markdown",
        "role": "Viewer"
      }
    ],
    "linux": {
      "deb": {
        "desktopTemplate": "linux/main.desktop.hbs"
      },
      "rpm": {
        "desktopTemplate": "linux/main.desktop.hbs"
      }
    }
  }
}
